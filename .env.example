# Supabase — required for auth and database access
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Supabase (client-side, exposed to the browser via Vite)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>

# Cloudflare R2 — required for file storage (server-side only, never expose to browser)
# Get from: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=cadesk-documents

# App canonical URL — used in email confirmation links
VITE_APP_URL=https://your-production-domain.com

# Skip email confirmation on signup — "true" for local dev, unset for production
VITE_SKIP_EMAIL_CONFIRMATION=false

# Razorpay — required for payment processing (server-side only, never expose to browser)
RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
